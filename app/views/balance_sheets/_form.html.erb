<%= form_with(model: balance_sheet, class: "form") do |f| %>
  <% if balance_sheet.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% balance_sheet.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :closing_date, t("views.balance_sheets.form.closing_date") %>
    <%= f.date_field :closing_date, class: "form-control", required: true %>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Annuler", balance_sheets_path, class: "btn btn-outline" %>
  </div>
<% end %>
