<div class="auth-container">
  <h2>Créer un compte</h2>

  <%= render "shared/errors", resource: resource %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "form" }) do |f| %>
    <div class="form-row">
      <div class="form-group form-group-half">
        <%= f.label :firstname, "Prénom" %>
        <%= f.text_field :firstname, autofocus: true, class: "form-control" %>
      </div>
      <div class="form-group form-group-half">
        <%= f.label :lastname, "Nom" %>
        <%= f.text_field :lastname, class: "form-control" %>
      </div>
    </div>

    <div class="form-group">
      <%= f.label :email %>
      <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
    </div>

    <div class="form-group">
      <%= f.label :password, "Mot de passe" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
      <small class="form-hint"><%= "#{@minimum_password_length} caractères minimum" if @minimum_password_length %></small>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, "Confirmation du mot de passe" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
    </div>

    <div class="form-actions">
      <%= f.submit "Créer mon compte", class: "btn btn-primary" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= link_to "Déjà inscrit ? Se connecter", new_session_path(resource_name) %>
  </div>
</div>
